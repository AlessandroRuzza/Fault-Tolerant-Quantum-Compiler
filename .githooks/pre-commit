#!/usr/bin/env bash
# Keep large config/ files out of commits: any staged file under config/ whose
# staged content is >= 10 MB is unstaged (with a warning) so the commit still
# proceeds with the smaller files. The file itself is left untouched on disk.
set -euo pipefail

MAX_BYTES=$((10 * 1024 * 1024)) # 10 MiB

while IFS= read -r path; do
    [ -z "$path" ] && continue
    size=$(git cat-file -s ":$path" 2>/dev/null || echo 0)
    if [ "$size" -ge "$MAX_BYTES" ]; then
        git restore --staged -- "$path"
        mb=$((size / 1024 / 1024))
        printf 'pre-commit: %s is %s MB (>= 10 MB) — left unstaged, not committed\n' "$path" "$mb" >&2
    fi
done < <(git diff --cached --name-only --diff-filter=ACM -- config/ benchmarks/)

exit 0
