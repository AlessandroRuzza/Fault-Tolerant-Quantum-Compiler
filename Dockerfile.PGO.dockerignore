# Version control — largest exclusion, never needed in the build context
.git/
.gitmodules

# Build artifacts — rebuilt from source inside Docker.
# build-pgo-gen/ is the instrumented build dir created by build_pgo_docker.sh
# when run on the host; never ship it into the context.
build/
build-pgo-gen/

# Python virtualenv
.env/
env/
__pycache__/
*.pyc
*.pyo

# IDE and local tooling
.vscode/
.claude/
.codex

# Large generated outputs (regenerated at runtime / build time)
benchmarks/logs/
benchmarks/results/
qasm_graphs/

# Visualization frames
visualization/gaussian_frames/*.png
visualization/gaussian_frames/*.dat
visualization/gaussian_frames/*.gp

# Generated / temporary benchmark configs.
# NOTE: config/, qasms/ and scripts/ are intentionally kept — the PGO builder
# runs the `profile` benchmark during the build and needs them.
config/__bench_*.json
config/*_expanded.json
config/*_expanded.status.jsonl
config/executed/
data/config/executed/

# QASMBench checkout
QASMBench-master/

# Misc large / generated files
*.png
*.svg
*.ans
*.mp4
*.gif
merged_distinct*
tmp/
callgrind*.out
perf.data*
